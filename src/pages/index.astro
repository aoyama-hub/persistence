---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Layout title="persistence">
	<section class="intro">
		<p>Documenting insights, systems optimization, and core technical mechanics.</p>
	</section>
	<hr />
	<ul class="post-list">
		{posts.map(post => (
			<li>
				<span class="date">
					{post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
				</span>
				<a href={`${base}/posts/${post.slug}/`}>{post.data.title}</a>
				{post.data.description && <p class="desc">{post.data.description}</p>}
			</li>
		))}
	</ul>
</Layout>

<style>
	hr {
		border: 0;
		border-top: 1px solid var(--muted);
		opacity: 0.2;
		margin: 2rem 0;
	}
	.post-list {
		list-style: none;
		padding: 0;
		margin: 0;
	}
	.post-list li {
		margin-bottom: 2rem;
	}
	.date {
		display: block;
		font-size: 0.85rem;
		color: var(--muted);
	}
	.post-list a {
		font-size: 1.25rem;
		font-weight: 600;
		text-decoration: none;
	}
	.post-list a:hover {
		text-decoration: underline;
	}
	.desc {
		margin: 0.25rem 0 0 0;
		color: var(--muted);
	}
</style>