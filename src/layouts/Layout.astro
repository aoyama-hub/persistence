---
interface Props {
	title: string;
	description?: string;
}

const { title, description = "A learning and teaching blog." } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
		<!-- Load Google Fonts asynchronously for optimal PageSpeed -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400..700;1,400..700&family=Plus+Jakarta+Sans:wght@400;500;700&display=swap" rel="stylesheet">
		<title>{title}</title>
	</head>
	<body>
		<header>
			<nav>
				<a href={`${base}/`} class="site-title">persistence</a>
			</nav>
		</header>
		<main>
			<slot />
		</main>
	</body>
</html>

<style is:global>
	:root {
		--bg: #f5f8f6;          /* Calm pastel sage/cream background */
		--text: #1b2e29;        /* High-contrast deep dark forest green */
		--muted: #4e6b62;       /* Mid-tone slate green for meta text */
		--accent: #337a63;      /* Muted green accent for links */
		--code-bg: #e2ebe7;     /* Soft sage container for inline code and syntax borders */
		--line-height: 1.8;
		--font-serif: 'Lora', Georgia, serif;
		--font-sans: 'Plus Jakarta Sans', sans-serif;
	}

	body {
		background-color: var(--bg);
		color: var(--text);
		font-family: var(--font-serif); /* Focus on beautiful, slow-paced reading */
		line-height: var(--line-height);
		margin: 0;
		padding: 0;
		display: flex;
		flex-direction: column;
		align-items: center;
	}

	header, main {
		width: 100%;
		max-width: 68ch; /* Mathematically golden line measure (65-75 chars) */
		padding: 2.5rem 1.5rem;
		box-sizing: border-box;
	}

	header {
		padding-bottom: 0;
	}

	nav a {
		text-decoration: none;
		color: var(--text);
		font-family: var(--font-sans);
		font-weight: 700;
		font-size: 1.25rem;
		letter-spacing: -0.02em;
	}

	h1, h2, h3, h4 {
		font-family: var(--font-serif);
		color: var(--text);
		line-height: 1.25;
		margin-top: 2.5rem;
		font-weight: 600;
	}

	a {
		color: var(--accent);
		text-underline-offset: 3px;
	}

	pre {
		background-color: #1a2622 !important; /* Low-glare dark-slate container */
		padding: 1.25rem;
		border-radius: 8px;
		overflow-x: auto;
		font-size: 0.9rem;
		border: 1px solid #d0ded8;
		box-shadow: inset 0 2px 8px rgba(0,0,0,0.05);
	}

	code {
		font-family: ui-monospace, SFMono-Regular, "SF Pro Mono", Menlo, Monaco, Consolas, monospace;
	}

	/* Clean support for inline code tags */
	:not(pre) > code {
		background-color: var(--code-bg);
		padding: 0.2rem 0.4rem;
		border-radius: 4px;
		font-size: 0.9em;
		color: #213f35;
	}

	/* Responsive images configuration for Jupyter assets */
	img {
		max-width: 100%;
		height: auto;
		border-radius: 6px;
		border: 1px solid var(--code-bg);
		margin: 1.5rem 0;
	}
</style>