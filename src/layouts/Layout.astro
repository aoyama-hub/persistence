---
interface Props {
	title: string;
	description?: string;
}

const { title, description = "A learning and teaching blog." } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
		<!-- High-performance fonts configuration -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400..700;1,400..700&family=Plus+Jakarta+Sans:wght@400;500;700&display=swap" rel="stylesheet">
		<title>{title}</title>
	</head>
	<body>
		<header class="global-header">
			<nav class="nav-bar">
				<a href={`${base}/`} class="site-title">persistence</a>
				<div class="nav-links">
					<a href={`${base}/about/`} class="nav-item">About</a>
				</div>
			</nav>
		</header>
		<main class="global-main">
			<slot />
		</main>
	</body>
</html>

<style is:global>
	:root {
		--bg: #ecf3ee;          /* Soft, warmer organic pastel green */
		--text: #172824;        /* Dark forest charcoal for comfortable contrast */
		--muted: #4d665f;       /* Deep warm slate green for subheadings */
		--accent: #235c4a;      /* Forest-accent green for highly readable active links */
		--border: #d4e0d9;      /* Delicate border alignment green */
		--code-bg: #dde6e1;     /* Contrast offset container for code/inputs */
		--font-serif: 'Lora', Georgia, serif;
		--font-sans: 'Plus Jakarta Sans', sans-serif;
	}

	@media (prefers-color-scheme: dark) {
		:root {
			--bg: #121a18;      /* Deep low-light jungle slate */
			--text: #e1ede8;    /* Comfortable cream text */
			--muted: #8da39d;
			--accent: #5abfa0;  /* Bright mint accent */
			--border: #243531;
			--code-bg: #1b2623;
		}
	}

	* {
		box-sizing: border-box;
	}

	body {
		background-color: var(--bg);
		color: var(--text);
		font-family: var(--font-serif);
		line-height: 1.75;
		margin: 0;
		padding: 0;
		min-height: 100vh;
		display: flex;
		flex-direction: column;
		align-items: center;
	}

	.global-header {
		width: 100%;
		max-width: 1000px;
		padding: 2rem 1.5rem 0 1.5rem;
		box-sizing: border-box;
	}

	.nav-bar {
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding-bottom: 1rem;
		border-bottom: 1px solid var(--border);
	}

	.site-title {
		text-decoration: none;
		color: var(--text);
		font-family: var(--font-sans);
		font-weight: 700;
		font-size: 1.25rem;
		letter-spacing: -0.02em;
	}

	.nav-links {
		display: flex;
		gap: 1.5rem;
	}

	.nav-item {
		text-decoration: none;
		color: var(--muted);
		font-family: var(--font-sans);
		font-size: 0.95rem;
		font-weight: 500;
		transition: color 0.15s ease;
	}

	.nav-item:hover {
		color: var(--accent);
	}

	.global-main {
		width: 100%;
		max-width: 1000px;
		padding: 2.5rem 1.5rem;
		box-sizing: border-box;
		flex-grow: 1;
	}

	/* Beautiful responsive images for notebooks */
	img {
		max-width: 100%;
		height: auto;
		border-radius: 8px;
		border: 1px solid var(--border);
		margin: 1.5rem 0;
	}

	/* Shiki syntax code highlighting container */
	pre {
		background-color: #121a18 !important; /* Low-fatigue slate */
		padding: 1.25rem;
		border-radius: 8px;
		overflow-x: auto;
		font-size: 0.9rem;
		border: 1px solid var(--border);
		box-shadow: inset 0 2px 8px rgba(0,0,0,0.1);
	}

	code {
		font-family: ui-monospace, SFMono-Regular, "SF Pro Mono", Monaco, Consolas, monospace;
	}

	:not(pre) > code {
		background-color: var(--code-bg);
		padding: 0.2rem 0.4rem;
		border-radius: 4px;
		font-size: 0.9em;
		color: var(--accent);
	}
</style>